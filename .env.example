# Copy to .env and adjust as needed:
#   cp .env.example .env

# Port published on the host (left side of docker compose ports mapping)
HOST_PORT=9655

# Port the proxy listens on inside the container
PORT=9655

# Bind address inside the container (keep 0.0.0.0 for Docker)
HOST=0.0.0.0

# Skip the interactive startup menu (recommended for containers)
NON_INTERACTIVE=1

# Host path to your DeepSeek auth file (create it first with: npm run auth)
DEEPSEEK_AUTH_FILE=./deepseek-auth.json

# Auth file path inside the container
DEEPSEEK_AUTH_PATH=/config/deepseek-auth.json

# Container / image settings
CONTAINER_NAME=free-deepseek-api
IMAGE_NAME=free-deepseek-api
IMAGE_TAG=local
RESTART_POLICY=unless-stopped

# Optional compose project name
# COMPOSE_PROJECT_NAME=free-deepseek-api
